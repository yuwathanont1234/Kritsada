# ============================================================
# Luxury Authenticator — Environment Variable Template
# ============================================================
# Copy this file to `.env` and fill in real values. The .env file
# is gitignored (see .gitignore) — never commit secrets.
#
# Two conventions in use:
#   • EXPO_PUBLIC_*  → shipped INTO the mobile app bundle (visible
#                      to clients). Use ONLY for keys safe to expose:
#                      anon JWT, public model IDs, dimension ints.
#   • Plain names    → server-side only (Python harvesters, EAS
#                      build secrets). NEVER prefix with EXPO_PUBLIC_.
#
# Production builds: set the same vars as EAS secrets so they ship
# with the binary:
#   eas secret:create --scope project --name <NAME> --value "<value>"
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Project URL: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
# Anon JWT — safe to ship in the app. Read-only on RLS-locked tables.
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service-role JWT — backend ONLY (Python scripts, harvesters).
# Bypasses RLS. NEVER ship to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Edge functions / Replicate ────────────────────────────────
# Set to "true" to route all AI calls via Supabase Edge Functions
# (Gemini key + Replicate token stay server-side). Strongly
# recommended for production.
EXPO_PUBLIC_USE_EDGE_FUNCTIONS=true

# Replicate model version + output dimensionality. Used by the
# embed-image Edge Function + the Python reproject scripts.
EXPO_PUBLIC_REPLICATE_EMBED_MODEL=<dinov3-vit-l16-version-hash>
EXPO_PUBLIC_REPLICATE_EMBED_DIM=1024

# Optional: shared secret to gate non-Supabase callers of embed-image
# (e.g. the keep-warm cron). When unset, the function falls back to
# JWT-only auth.
EMBED_FUNCTION_URL=https://<your-project-ref>.supabase.co/functions/v1/embed-image
EMBED_FUNCTION_SECRET=<random-32-byte-hex>

# ── AI providers (server-side ONLY — never EXPO_PUBLIC_*) ─────
# Required if USE_EDGE_FUNCTIONS=false (NOT recommended).
GEMINI_API_KEY=AIza...
REPLICATE_API_TOKEN=r8_...

# Optional fallback for client direct-call path. ONLY set in dev.
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_REPLICATE_API_TOKEN=

# ── Apify (brand image scraping — server-side / scripts only) ──
# Used by scripts/scrape_apify.py to scrape the 15 brands lacking
# native scrapers (A. Lange, F.P. Journe, JLC, Hublot, Breitling,
# Zenith, Bvlgari, Franck Muller, GP, MB&F, URWERK, Bovet, Ulysse
# Nardin, Parmigiani, Longines, Seiko).
#
# Sign up:  https://apify.com  (Free tier = $5 credit ≈ 2,000 items)
# Token:    https://console.apify.com/settings/integrations
# Cost:     ~$2.50 per 1,000 items = ~฿130 for full 15-brand seed.
APIFY_API_TOKEN=apify_api_...

# ── Gemini cost/quality routing (Supabase Edge Function env) ──
# These env vars are read by `supabase/functions/analyze-watch`
# and control which Gemini model handles each call type. Set them
# via `supabase secrets set <NAME>=<value>` — they do NOT need
# EXPO_PUBLIC_ prefix because they only matter on the server.
#
# Defaults (when unset) prioritise cost — Flash-tier for everything.
# Flip to "false" only after measuring quality regression on A/B.
#
# AUTH_USE_FLASH=true → route authenticity assessment to Flash
#   (saves ~฿0.30/scan vs Pro; Flash 2.5+ is strong enough for
#    case finish / dial typography / hand alignment checks).
AUTH_USE_FLASH=true
#
# FORCE_GROUNDED_TO_FLASH=true → lock identify-grounded retries
#   AND price lookups to the Flash URL even when GEMINI_PRO_MODEL
#   points at a true Pro endpoint. Saves ~฿0.60/grounded call.
#   Grounding fee ($35/1K queries) is the same on Flash and Pro,
#   so we lose nothing by paying Flash model rates underneath.
FORCE_GROUNDED_TO_FLASH=true
#
# Model overrides (rarely needed — defaults track latest Flash).
# GEMINI_FLASH_MODEL=gemini-3-flash-preview
# GEMINI_PRO_MODEL=gemini-3.5-flash

# ── Analytics & Monitoring ────────────────────────────────────
# PostHog — product analytics + funnel + session replay.
# Sign up at https://posthog.com/signup (free 1M events/month).
# Create a project → React Native → copy the Project API Key.
EXPO_PUBLIC_POSTHOG_KEY=phc_<your-project-key>
# Region: https://app.posthog.com (US) or https://eu.posthog.com (EU)
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry — crash + error reporting.
# Sign up at https://sentry.io/signup (free 5K errors/month).
# Project Settings → Client Keys (DSN) → copy.
EXPO_PUBLIC_SENTRY_DSN=https://<key>@oXXXXX.ingest.sentry.io/<project-id>

# Sentry auth token for sourcemap upload during EAS build.
# NEVER ship to client — set as EAS build secret only:
#   eas secret:create --scope project --name SENTRY_AUTH_TOKEN --value <token>
# Generate at https://sentry.io/settings/account/api/auth-tokens/
# with scope: project:releases
SENTRY_AUTH_TOKEN=
# Used by @sentry/react-native expo plugin to associate uploads
# with the correct project. Set these in EAS build secrets too.
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=luxury-authenticator

# ── App version (optional override) ──────────────────────────
# Shown in scan/cost/funnel events. Defaults to '1.0.0' if unset.
EXPO_PUBLIC_APP_VERSION=1.0.0

# ── Tester build flag (optional) ─────────────────────────────
# Set to "true" only on internal TestFlight / closed-beta builds.
# Enables the tester feedback panel + extra event logging.
EXPO_PUBLIC_TESTER_BUILD=false

# ── Python backend secrets (harvesters, indexers) ────────────
# These mirror the EXPO_PUBLIC_* keys above. Used only by scripts
# in scripts/ — never read by the mobile app.
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
EMBEDDING_VERSION=v4
# Google Custom Search (used by URL hunter scripts)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
# Google Vision API (optional OCR fallback)
GOOGLE_VISION_API_KEY=
