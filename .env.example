# --- Postgres / Supabase ---
# Direct Postgres connection used by the API and the harvester worker.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# --- Supabase Edge Function: embed-image (DINOv3 -> 1024-dim) ---
EMBED_FUNCTION_URL=https://<project-ref>.supabase.co/functions/v1/embed-image
EMBED_FUNCTION_SECRET=replace-with-shared-secret

# --- DINOv3 inference backend (called from inside the Edge Function) ---
# Any endpoint that accepts an image and returns a 1024-dim float array.
DINOV3_ENDPOINT=https://your-dinov3-host/embed
DINOV3_API_KEY=replace-with-key

# --- Gemini (zero-shot identification + catalog resolution) ---
GEMINI_API_KEY=replace-with-key
GEMINI_MODEL=gemini-2.5-flash

# --- Pipeline config ---
# Bump this string whenever DINOv3 or the projection MLP changes.
EMBEDDING_VERSION=dinov3-vitl16/probe-v1
PROJECTION_WEIGHTS_PATH=app/weights/linear_probe.npz

# Cosine-similarity threshold for declaring a retrieval match (0..1).
MATCH_THRESHOLD=0.82
# Minimum Gemini confidence (0..1) before a harvested ref may be persisted.
HARVEST_CONFIDENCE_THRESHOLD=0.7
# Harvested studio image must look at least this similar to the user's scan
# that triggered the job, otherwise it is rejected as a wrong-ref/wrong-image.
CROSSCHECK_MIN_SIMILARITY=0.55

# Fine-grained heatmap verdict (patch anomaly score 0..1).
HEATMAP_AUTHENTIC_THRESHOLD=0.25
HEATMAP_SUSPECT_THRESHOLD=0.45

# Shared secret guarding the /admin/* verification endpoints.
ADMIN_API_KEY=replace-with-admin-secret

WORKER_POLL_INTERVAL_SECONDS=3
MAX_IMAGE_BYTES=104857600
