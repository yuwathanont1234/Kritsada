# macOS
.DS_Store

# Env — broad wildcard catches .env, .env.bak, .env.local, etc.
# Anything matching .env* is ignored EXCEPT the public .env.example
# (the `!` exception lets the public template stay tracked).
.env*
!.env.example

# Session / scratch notes that may contain plaintext secrets,
# debug snapshots, or in-flight design docs. Keep local only.
SESSION_STATE.md
SESSION_STATE.*.md
SESSION_LOG_*.md
scratch/

# Expo
.expo/
dist/
web-build/

# Node
node_modules/

# Python (backend harvesters, indexers, FastAPI app/)
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Logs & scratch build artifacts (e.g. mega-overnight-*.log, config.py.bak)
*.log
*.bak
*.tsbuildinfo

# Supabase
supabase/.temp/

# IDE
.vscode/
.idea/
data/auth-train/
