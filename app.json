{
  "expo": {
    "name": "Luxury Authenticator",
    "slug": "luxury-authenticator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#090A0C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kritsada.luxuryauthenticator",
      "infoPlist": {
        "NSCameraUsageDescription": "This app requires camera access to take high-resolution photos of luxury watches for AI authenticity checks.",
        "NSPhotoLibraryUsageDescription": "This app requires photo library access to upload watch photos for scanning.",
        "NSMicrophoneUsageDescription": "Required to ask questions to the AI watchmaker assistant using voice commands.",
        "NSSpeechRecognitionUsageDescription": "Converts your voice commands into text queries for the AI watchmaker assistant.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.kritsada.luxuryauthenticator",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1115"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Camera access is required to capture watch photos.",
          "recordAudioAndroid": false
        }
      ],
      "expo-audio",
      "expo-font",
      "expo-asset",
      "expo-speech-recognition",
      "./plugins/withTabletSupport.js"
    ],
    "extra": {
      "appName": "Luxury Authenticator",
      "eas": {
        "projectId": "placeholder-eas-project-id"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/placeholder-eas-project-id"
    }
  }
}
