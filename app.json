{
  "expo": {
    "name": "Luxury Authenticator",
    "slug": "luxury-authenticator",
    "scheme": "luxuryauthenticator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#090A0C"
    },
    "ios": {
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.kritsada.luxuryauthenticator",
      "infoPlist": {
        "NSCameraUsageDescription": "ใช้กล้องเพื่อถ่ายภาพนาฬิกาความละเอียดสูงสำหรับการตรวจสอบความแท้ด้วย AI · Camera access is used to take high-resolution watch photos for AI authenticity checks.",
        "NSPhotoLibraryUsageDescription": "ใช้คลังภาพเพื่อเลือกรูปนาฬิกาสำหรับการสแกน · Photo library access is used to pick watch images for scanning."
      }
    },
    "android": {
      "package": "com.kritsada.luxuryauthenticator",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1115"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Camera access is required to capture watch photos.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": false
        }
      ],
      "expo-font",
      "expo-asset",
      "./plugins/withTabletSupport.js",
      [
        "@sentry/react-native",
        {
          "url": "https://sentry.io/",
          "organization": "your-org-slug",
          "project": "luxury-authenticator"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#D4B98C",
          "defaultChannel": "default"
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "appName": "Luxury Authenticator",
      "eas": {
        "projectId": "a694d76a-4616-41b8-a109-a3ab58f666cd"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "yuwathanont"
  }
}
